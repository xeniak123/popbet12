# Skopiuj ten plik jako .env:  cp .env.example .env
# i uzupełnij wartości.

# MongoDB Atlas: Database -> Connect -> Drivers -> skopiuj URI, podmień hasło.
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=popbet_database

# Wygeneruj losowy sekret, np.:  openssl rand -hex 32
JWT_SECRET=change-me
JWT_ALG=HS256
ACCESS_TOKEN_DAYS=30

EMERGENT_PUSH_KEY=placeholder

# Klucz do panelu /admin — wygeneruj losowy:  openssl rand -hex 16
ADMIN_KEY=change-me-admin

# Automat sportowy — darmowy klucz z dashboard.api-football.com
APIFOOTBALL_KEY=
# Ligi do automatycznego dodawania (ID z API-Football)
AUTO_LEAGUES=106,107,39,140,78,135,61,2
# Typy rynków: home_win (czy gospodarz wygra), over25 (czy padną 3+ gole)
AUTO_MARKETS=home_win,over25
